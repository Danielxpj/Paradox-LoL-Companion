<Window x:Class="ParadoxLoLCompanion.App.Update.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Topmost="True" ShowInTaskbar="True" Icon="../img/app.ico"
        Title="Actualizando Paradox LoL Companion"
        Width="440" Height="212" Background="Transparent" AllowsTransparency="True">

    <Border Background="{StaticResource PageBg}" BorderBrush="{StaticResource GoldBorder}"
            BorderThickness="1" Padding="24,20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="PARADOX · LoL COMPANION"
                       FontFamily="Cascadia Mono, Consolas" FontSize="12"
                       Foreground="{StaticResource ConsoleFg}" />

            <TextBlock Grid.Row="1" Margin="0,10,0,0" Text="Actualización disponible"
                       FontFamily="Bahnschrift, Segoe UI" FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}" />

            <TextBlock Grid.Row="2" x:Name="VersionLine" Margin="0,6,0,0"
                       FontFamily="Cascadia Mono, Consolas" FontSize="12"
                       Foreground="{StaticResource TextMuted}" />

            <ProgressBar Grid.Row="3" x:Name="Bar" Height="8" Minimum="0" Maximum="100" Value="0"
                         Margin="0,14,0,0"
                         Background="{StaticResource CardBg}"
                         BorderBrush="{StaticResource CardBorderStrong}" BorderThickness="1"
                         Foreground="{StaticResource ConsoleFg}" />

            <TextBlock Grid.Row="4" x:Name="StatusText" Margin="0,10,0,0" Text="Conectando…"
                       FontFamily="Cascadia Mono, Consolas" FontSize="11"
                       Foreground="{StaticResource TextFaint}" />
        </Grid>
    </Border>
</Window>
