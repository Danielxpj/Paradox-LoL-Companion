<Window x:Class="ParadoxLoLCompanion.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ParadoxLoLCompanion.App"
        mc:Ignorable="d"
        Title="Paradox LoL Companion" Height="780" Width="1220" MinHeight="640" MinWidth="1000"
        Icon="img/app.ico"
        Background="{StaticResource PageBg}">
    <DockPanel>

        <!-- ================= HEADER ================= -->
        <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBg}"
                BorderBrush="{StaticResource GoldBorder}" BorderThickness="0,0,0,1" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Marca + contexto actual (badge rojo cuando hay partida en vivo) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PARADOX" FontFamily="{StaticResource DisplayFont}" FontSize="22"
                               Foreground="{StaticResource Gold}" VerticalAlignment="Center" />
                    <TextBlock Text="LoL Companion" FontFamily="{StaticResource DisplayFont}" FontSize="22"
                               Foreground="{StaticResource TextPrimary}" Margin="8,0,0,0" VerticalAlignment="Center" />
                    <Border Margin="18,0,0,0" VerticalAlignment="Center" Padding="10,4"
                            BorderThickness="1" CornerRadius="2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="{StaticResource CardBorderStrong}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ContextIsLive}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource Danger}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="●" FontSize="9" VerticalAlignment="Center" Margin="0,0,7,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextFaint}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ContextIsLive}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Danger}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding ContextLabel}" FontFamily="{StaticResource HudFont}"
                                       FontSize="12" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ContextIsLive}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Danger}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Estado de conexiones + acciones -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center"
                                ToolTip="Connection to the running game (Live Client Data API)">
                        <Ellipse Width="8" Height="8" Fill="{Binding LiveStatusBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="GAME" Margin="7,0,5,0" Foreground="{StaticResource TextFaint}"
                                   FontFamily="{StaticResource HudFont}" FontSize="10.5" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding LiveStatusText}" Foreground="{StaticResource TextMuted}"
                                   FontFamily="{StaticResource HudFont}" FontSize="10.5" VerticalAlignment="Center"
                                   MaxWidth="130" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center"
                                ToolTip="Connection to the LoL client (champ select, queue info, runes)">
                        <Ellipse Width="8" Height="8" Fill="{Binding LcuStatusBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="CLIENT" Margin="7,0,5,0" Foreground="{StaticResource TextFaint}"
                                   FontFamily="{StaticResource HudFont}" FontSize="10.5" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding LcuStatusText}" Foreground="{StaticResource TextMuted}"
                                   FontFamily="{StaticResource HudFont}" FontSize="10.5" VerticalAlignment="Center"
                                   MaxWidth="150" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Button Content="UPDATE DATA" Command="{Binding CheckUpdatesCommand}"
                            Margin="0,0,12,0" VerticalAlignment="Center"
                            ToolTip="Checks whether a newer version of the game data (Data Dragon) is available" />
                    <Border BorderBrush="{StaticResource CardBorderStrong}" BorderThickness="1"
                            CornerRadius="2" Padding="10,4">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="REPLAY" IsChecked="{Binding ReplayMode}" VerticalAlignment="Center"
                                      ToolTip="Demo mode: feeds a recorded game so you can explore the app without LoL running" />
                            <TextBlock Text="/" Foreground="{StaticResource TextFaint}" Margin="10,0,4,0"
                                       VerticalAlignment="Center" FontFamily="{StaticResource HudFont}" />
                            <ComboBox SelectedIndex="{Binding ReplayScenarioIndex}"
                                      VerticalAlignment="Center" MinWidth="130" Height="24"
                                      ToolTip="Replay scenario">
                                <ComboBoxItem Content="RIFT" />
                                <ComboBoxItem Content="ARAM: MAYHEM" />
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= CENTRO + CONSOLA (splitter ajustable y show/hide) ================= -->
        <Grid x:Name="CenterGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="220" />
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="ConsoleRow" Height="180" MinHeight="120" />
            </Grid.RowDefinitions>

            <!-- Divisor arrastrable entre el dashboard y la consola. -->
            <GridSplitter x:Name="ConsoleSplitter" Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" Cursor="SizeNS"
                          ToolTip="Drag to resize the console" />

            <Border Grid.Row="2" Background="{StaticResource ConsoleBg}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="14,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="●" Foreground="{StaticResource Cyan}" FontSize="10"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="RAW DATA CONSOLE" Foreground="{StaticResource TextFaint}"
                                       FontFamily="{StaticResource DisplayFontCondensed}" FontSize="12"
                                       FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                        <!-- Atribución de las fuentes de datos (siempre visible). -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Powered by" Foreground="{StaticResource TextFaint}"
                                       FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="OP.GG" Foreground="{StaticResource Info}"
                                       FontFamily="{StaticResource DisplayFontCondensed}" FontWeight="Bold"
                                       FontSize="13" Margin="5,0,0,0" VerticalAlignment="Center"
                                       ToolTip="Champion build, runes and skill-order stats come from OP.GG" />
                            <TextBlock Text="·" Foreground="{StaticResource TextFaint}"
                                       FontSize="12" Margin="6,0,6,0" VerticalAlignment="Center" />
                            <TextBlock Text="Data Dragon" Foreground="{StaticResource Cyan}"
                                       FontFamily="{StaticResource DisplayFontCondensed}" FontWeight="Bold"
                                       FontSize="13" VerticalAlignment="Center"
                                       ToolTip="Champion and item catalog data from Riot's Data Dragon" />
                            <TextBlock Text="·" Foreground="{StaticResource TextFaint}"
                                       FontSize="12" Margin="6,0,6,0" VerticalAlignment="Center" />
                            <TextBlock Text="Claude Fable" Foreground="{StaticResource Gold}"
                                       FontFamily="{StaticResource DisplayFontCondensed}" FontWeight="Bold"
                                       FontSize="13" VerticalAlignment="Center"
                                       ToolTip="Built with Claude Fable" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{Binding PauseLabel}" Command="{Binding PauseConsoleCommand}"
                                    Padding="10,2" Margin="4,0" FontSize="12" />
                            <Button Content="Clear" Command="{Binding ClearConsoleCommand}" Padding="10,2" Margin="4,0" FontSize="12" />
                            <Button Content="Save" Command="{Binding SaveConsoleCommand}" Padding="10,2" Margin="4,0" FontSize="12" />
                            <Button x:Name="ToggleConsoleButton" Content="Hide" Click="OnToggleConsole"
                                    Padding="10,2" Margin="12,0,0,0" FontSize="12"
                                    ToolTip="Show or hide the console log" />
                        </StackPanel>
                    </Grid>
                    <ListBox x:Name="ConsoleList" ItemsSource="{Binding ConsoleLines}"
                             Background="Transparent" Foreground="{StaticResource ConsoleFg}"
                             BorderThickness="0" FontFamily="{StaticResource MonoFont}" FontSize="12"
                             Margin="14,0,0,4"
                             VirtualizingPanel.IsVirtualizing="False"
                             ScrollViewer.CanContentScroll="False"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ================= CENTRO: pestañas ================= -->
            <TabControl Grid.Row="0" SelectedIndex="{Binding SelectedTabIndex}" Background="Transparent"
                        BorderThickness="0" Margin="12,6,12,0">

                <!-- PESTAÑA PARTIDA -->
                <TabItem Header="MATCH">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,4,0,16">

                            <!-- ===== FILA 1: ENEMY X-RAY (2/3) + SUMMARY mini (1/3) ===== -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Padding="16,10">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PhysPct}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock DockPanel.Dock="Right" Text="damage weighted by how fed each enemy is"
                                                       Style="{StaticResource SectionComment}" VerticalAlignment="Center" />
                                            <TextBlock Text="ENEMY X-RAY" FontFamily="{StaticResource HudFont}" FontSize="13"
                                                       FontWeight="Bold" Foreground="{StaticResource Gold}" />
                                        </DockPanel>
                                        <Grid Margin="0,2,0,6">
                                            <StackPanel HorizontalAlignment="Left">
                                                <TextBlock Text="PHYSICAL" FontFamily="{StaticResource HudFont}" FontSize="10.5"
                                                           Foreground="{StaticResource Danger}" />
                                                <TextBlock Text="{Binding PhysPct}" FontFamily="{StaticResource DisplayFont}"
                                                           FontSize="30" Foreground="{StaticResource Danger}" />
                                            </StackPanel>
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="MAGIC" FontFamily="{StaticResource HudFont}" FontSize="10.5"
                                                           Foreground="{StaticResource Info}" HorizontalAlignment="Right" />
                                                <TextBlock Text="{Binding MagicPct}" FontFamily="{StaticResource DisplayFont}"
                                                           FontSize="30" Foreground="{StaticResource Info}" HorizontalAlignment="Right" />
                                            </StackPanel>
                                        </Grid>
                                        <Border Height="10" CornerRadius="2" Background="{Binding DamageSplitBrush}" />
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <DockPanel Grid.Column="0">
                                                <Border DockPanel.Dock="Left" Width="3" Background="{StaticResource Danger}" Margin="0,2,10,2" />
                                                <StackPanel>
                                                    <TextBlock Text="RECOMMENDED" Style="{StaticResource CardTitle}" />
                                                    <TextBlock Text="{Binding RecommendedLine}" FontFamily="{StaticResource HudFont}"
                                                               FontSize="12" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </DockPanel>
                                            <DockPanel Grid.Column="1" Margin="14,0,0,0">
                                                <DockPanel.Style>
                                                    <Style TargetType="DockPanel">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SustainLine}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DockPanel.Style>
                                                <Border DockPanel.Dock="Left" Width="3" Background="{StaticResource Neon}" Margin="0,2,10,2" />
                                                <StackPanel>
                                                    <TextBlock Text="SUSTAIN" Style="{StaticResource CardTitle}" />
                                                    <TextBlock Text="{Binding SustainLine}" FontFamily="{StaticResource HudFont}"
                                                               FontSize="12" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </DockPanel>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Tiles de enemigos: retrato, KDA, rol; el más fed en rojo. -->
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding EnemyTiles}" VerticalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="88" Margin="3,0" Padding="6,8" CornerRadius="2" BorderThickness="1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
                                                            <Setter Property="Background" Value="#0D120E" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsTopThreat}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource Danger}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <Grid Width="44" Height="44" HorizontalAlignment="Center">
                                                            <Border CornerRadius="2" BorderBrush="{StaticResource CardBorderStrong}" BorderThickness="1">
                                                                <Border.Background>
                                                                    <ImageBrush ImageSource="{Binding IconUrl, TargetNullValue={x:Null}}" Stretch="UniformToFill" />
                                                                </Border.Background>
                                                            </Border>
                                                            <!-- Overlay de respawn cuando está muerto. -->
                                                            <Border CornerRadius="2" Background="#C50A0D0B">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding RespawnText}" Value="">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding RespawnText}" FontFamily="{StaticResource HudFont}"
                                                                           FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Name}" FontFamily="{StaticResource HudFont}" FontSize="10.5"
                                                                   Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"
                                                                   Margin="0,5,0,0" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Kda}" FontFamily="{StaticResource HudFont}" FontSize="10"
                                                                   Foreground="{StaticResource TextFaint}" HorizontalAlignment="Center" />
                                                        <Border HorizontalAlignment="Center" Margin="0,4,0,0" CornerRadius="2" Padding="5,1">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="Transparent" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsTopThreat}" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource Danger}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Tag}" FontFamily="{StaticResource HudFont}" FontSize="9" FontWeight="Bold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{StaticResource TextFaint}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsTopThreat}" Value="True">
                                                                                <Setter Property="Foreground" Value="#0B0E0C" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                            <!-- SUMMARY mini: las 6 stats en grilla 3×2, misma info sin sección propia. -->
                            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="14,8">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="SUMMARY" FontFamily="{StaticResource HudFont}" FontSize="10"
                                               FontWeight="Bold" Foreground="{StaticResource Gold}" Margin="0,0,0,4" />
                                    <ItemsControl ItemsSource="{Binding Scorecards}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><UniformGrid Columns="3" /></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="2,3,10,3">
                                                    <TextBlock Style="{StaticResource CardTitle}" Text="{Binding Title}" />
                                                    <TextBlock FontFamily="{StaticResource DisplayFont}" FontSize="18"
                                                               Foreground="{StaticResource TextPrimary}" Text="{Binding Value}" />
                                                    <Border Height="2" CornerRadius="1" Background="{Binding Accent}" Margin="0,3,0,0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                            </Grid>

                            <!-- ===== FILA 2: ITEM ADVISOR (2/3) + rail de ADVICE (1/3) ===== -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                            <!-- ===== ASESOR DE ITEMS ===== -->
                            <DockPanel Margin="10,14,10,4">
                                <Border DockPanel.Dock="Right" BorderBrush="{StaticResource GoldBorder}" BorderThickness="1"
                                        CornerRadius="2" Padding="14,6" Background="#151109">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{StaticResource GoldBorder}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding GoldText}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Fill="{StaticResource Gold}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding GoldText}" Margin="9,0,7,0" FontFamily="{StaticResource DisplayFont}"
                                                   FontSize="17" Foreground="{StaticResource GoldBright}" VerticalAlignment="Center" />
                                        <TextBlock Text="GOLD" FontFamily="{StaticResource HudFont}" FontSize="10"
                                                   Foreground="{StaticResource TextFaint}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="ITEM ADVISOR" FontFamily="{StaticResource HudFont}" FontSize="13"
                                               FontWeight="Bold" Foreground="{StaticResource Gold}" />
                                    <TextBlock Text="// answers to the enemy threat" Style="{StaticResource SectionComment}"
                                               VerticalAlignment="Center" Margin="10,0,0,0" />
                                </StackPanel>
                            </DockPanel>
                            <!-- Selector de build como segmentos + avisos (starter/tienda/hint). -->
                            <StackPanel Margin="10,2,10,4">
                                <ItemsControl ItemsSource="{Binding BuildRoles}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <RadioButton GroupName="BuildRole" Content="{Binding Label}"
                                                         Style="{StaticResource SegmentRadio}"
                                                         IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="0,2,0,2" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                    <!-- Aviso de tienda abierta (ARAM: solo se compra muerto). -->
                                    <TextBlock Text="{Binding ShopAlertLine}" FontSize="14" FontWeight="Bold"
                                               TextWrapping="Wrap" Foreground="{StaticResource Amber}" Margin="0,6,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShopAlertLine}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!-- Compra inicial sugerida (arranque de ARAM). -->
                                    <DockPanel Margin="0,6,0,0">
                                        <DockPanel.Style>
                                            <Style TargetType="DockPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StarterLine}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DockPanel.Style>
                                        <Border DockPanel.Dock="Left" Width="24" Height="24" CornerRadius="4"
                                                Margin="0,0,10,0" VerticalAlignment="Center"
                                                BorderBrush="{StaticResource CardBorderStrong}" BorderThickness="1">
                                            <Image Source="{Binding StarterIconUrl, TargetNullValue={x:Null}}"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Border>
                                        <TextBlock Text="{Binding StarterLine}" FontSize="14" FontWeight="SemiBold"
                                                   TextWrapping="Wrap" Foreground="{StaticResource Cyan}"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding ItemPanelHint}" FontSize="13" TextWrapping="Wrap"
                                               FontFamily="{StaticResource HudFont}"
                                               Foreground="{StaticResource TextMuted}" Margin="0,8,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ItemPanelHint}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding ItemRecos}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><UniformGrid Columns="3" /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Card}" Padding="16,14">
                                            <StackPanel>
                                                <!-- Chip de categoría + prioridad relativa. -->
                                                <DockPanel Margin="0,0,0,12">
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Priority}"
                                                               FontFamily="{StaticResource HudFont}" FontSize="12" FontWeight="Bold"
                                                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                                                    <Border Style="{StaticResource Chip}" Background="{Binding CategoryBrush}"
                                                            HorizontalAlignment="Left">
                                                        <TextBlock Style="{StaticResource ChipText}" Foreground="#0B0E0C"
                                                                   Text="{Binding CategoryLabel}" />
                                                    </Border>
                                                </DockPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- Anillo radial: progreso del oro hacia el costo total. -->
                                                    <Grid Width="58" Height="62" Margin="0,0,12,0">
                                                        <Ellipse Width="55" Height="55" VerticalAlignment="Top"
                                                                 Stroke="{StaticResource CardBorderStrong}" StrokeThickness="3" />
                                                        <Path Stroke="{Binding AffordBrush}" StrokeThickness="3"
                                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                              Data="{Binding GoldFraction, Converter={StaticResource GoldArc}}" />
                                                        <Ellipse Width="40" Height="40" VerticalAlignment="Top" Margin="0,7.5,0,0">
                                                            <Ellipse.Fill>
                                                                <ImageBrush ImageSource="{Binding IconUrl, TargetNullValue={x:Null}}"
                                                                            Stretch="UniformToFill" />
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                        <Border Background="#0B0E0C" CornerRadius="2" Padding="4,1"
                                                                HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                                            <TextBlock Text="{Binding GoldPercent}" FontFamily="{StaticResource HudFont}"
                                                                       FontSize="9" FontWeight="Bold" Foreground="{Binding AffordBrush}" />
                                                        </Border>
                                                    </Grid>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"
                                                                   Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" />
                                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                            <Ellipse Width="9" Height="9" Fill="{StaticResource Gold}" VerticalAlignment="Center" />
                                                            <TextBlock Text="{Binding Cost}" Margin="7,0,0,0"
                                                                       FontFamily="{StaticResource DisplayFont}" FontSize="14"
                                                                       Foreground="{StaticResource Gold}" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </StackPanel>
                                                <!-- Barra de acción: la compra que procede AHORA. -->
                                                <Border BorderBrush="{Binding AffordBrush}" BorderThickness="1" CornerRadius="2"
                                                        Padding="10,5" Margin="0,12,0,0" Background="#0D120E">
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Right" Text="{Binding BuyBarCost}"
                                                                   FontFamily="{StaticResource HudFont}" FontSize="11"
                                                                   Foreground="{Binding AffordBrush}" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding BuyBarText}" FontFamily="{StaticResource HudFont}"
                                                                   FontSize="11" FontWeight="Bold" Foreground="{Binding AffordBrush}"
                                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                    </DockPanel>
                                                </Border>
                                                <TextBlock Text="{Binding Reasons}" FontSize="12" TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextMuted}" Margin="0,10,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Strip único: BOOTS + AUGMENTS + SKILLS en un solo renglón. -->
                            <Border Padding="16,8">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding BootsLine}" Value="" />
                                                    <Condition Binding="{Binding MayhemStatus}" Value="" />
                                                    <Condition Binding="{Binding SkillPriorityLine}" Value="" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <DockPanel>
                                    <!-- SKILLS a la derecha (mismo renglón que las botas, como en el HUD). -->
                                    <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="16,0,0,0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SkillPriorityLine}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="SKILLS" Style="{StaticResource CardTitle}" HorizontalAlignment="Right" />
                                        <TextBlock Text="{Binding SkillPriorityLine}" FontFamily="{StaticResource HudFont}"
                                                   FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"
                                                   HorizontalAlignment="Right" />
                                    </StackPanel>
                                    <!-- AUGMENTS (Mayhem) compacto: el guidance largo vive en el tooltip. -->
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"
                                                Margin="16,0,0,0" ToolTip="{Binding MayhemGuidance}">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MayhemStatus}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Border Style="{StaticResource Chip}" Background="{StaticResource Gold}" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource ChipText}" Foreground="#0B0E0C" Text="AUGMENTS" />
                                        </Border>
                                        <TextBlock Text="{Binding MayhemStatus}" FontFamily="{StaticResource HudFont}" FontSize="12"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                        <TextBlock Text="{Binding MayhemPickNow}" FontFamily="{StaticResource HudFont}" FontSize="12"
                                                   FontWeight="Bold" Foreground="{StaticResource Amber}"
                                                   VerticalAlignment="Center" Margin="10,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding MayhemPickNow}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding BootsLine}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Border Width="30" Height="30" CornerRadius="2"
                                                Margin="0,0,12,0" VerticalAlignment="Center"
                                                BorderBrush="{StaticResource CardBorderStrong}" BorderThickness="1">
                                            <Image Source="{Binding BootsIconUrl, TargetNullValue={x:Null}}"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding BootsName}" FontSize="14" FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                                                <Border Style="{StaticResource Chip}" Margin="10,0,0,0"
                                                        BorderBrush="{StaticResource Neon}" BorderThickness="1" Background="#12321F">
                                                    <TextBlock Style="{StaticResource ChipText}" Foreground="{StaticResource Neon}"
                                                               Text="{Binding BootsChip}" />
                                                </Border>
                                            </StackPanel>
                                            <!-- Razón en 1 línea: el texto completo (con la nota de amenaza) va al tooltip. -->
                                            <TextBlock Text="{Binding BootsSub}" FontFamily="{StaticResource HudFont}" FontSize="11"
                                                       Foreground="{StaticResource TextFaint}" Margin="0,3,0,0"
                                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding BootsSub}" />
                                        </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <!-- Items que conviene vender (ya no pegan con la build). -->
                            <Border Padding="16,10">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SellLine}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ItemsControl ItemsSource="{Binding SellRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,2">
                                                <Border DockPanel.Dock="Left" Width="24" Height="24" CornerRadius="4"
                                                        Margin="0,0,10,0" VerticalAlignment="Center"
                                                        BorderBrush="{StaticResource CardBorderStrong}" BorderThickness="1">
                                                    <Image Source="{Binding IconUrl, TargetNullValue={x:Null}}"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                </Border>
                                                <TextBlock Text="{Binding Text}" FontSize="13" TextWrapping="Wrap"
                                                           Foreground="{StaticResource Amber}" VerticalAlignment="Center" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                            <!-- Consejos de late game: elixir con build completa, Control Ward. -->
                            <Border Padding="16,10">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LateTipsLine}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding LateTipsLine}" FontSize="13" TextWrapping="Wrap"
                                           FontWeight="SemiBold" Foreground="{StaticResource Cyan}" />
                            </Border>
                            </StackPanel>

                            <!-- Rail derecho: feed de consejos compacto (sin categoría Items — duplica el panel). -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="ADVICE" FontFamily="{StaticResource HudFont}" FontSize="13"
                                           FontWeight="Bold" Foreground="{StaticResource Gold}" Margin="10,17,0,7" />
                                <ItemsControl ItemsSource="{Binding Advice}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource Card}" Padding="8,6">
                                                <DockPanel>
                                                    <Border DockPanel.Dock="Left" Width="3" CornerRadius="2"
                                                            Background="{Binding Severity}" Margin="0,0,8,0" />
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Category}" Style="{StaticResource CardTitle}" />
                                                        <TextBlock Text="{Binding Message}" FontSize="12" TextWrapping="Wrap"
                                                                   Foreground="{StaticResource TextPrimary}" />
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            </Grid>

                            <!-- Tabla de jugadores -->
                            <StackPanel>
                                    <TextBlock Text="PLAYERS" Style="{StaticResource SectionHeader}" />
                                    <Border Style="{StaticResource Card}" Padding="10">
                                        <DataGrid ItemsSource="{Binding Players}" AutoGenerateColumns="False"
                                                  IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="None"
                                                  Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                                                  CanUserAddRows="False" HorizontalScrollBarVisibility="Disabled"
                                                  FontSize="12" RowHeight="26">
                                            <DataGrid.Columns>
                                                <!-- Barra de color de equipo: azul = aliados, rojo = enemigos. -->
                                                <DataGridTemplateColumn Width="Auto">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Border Width="4" CornerRadius="2" Background="{Binding TeamBrush}"
                                                                    Margin="2,3" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Champion" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Width="22" Height="22" CornerRadius="3" Margin="0,0,8,0"
                                                                        VerticalAlignment="Center"
                                                                        BorderBrush="{StaticResource CardBorderStrong}" BorderThickness="1">
                                                                    <Image Source="{Binding ChampionIconUrl, TargetNullValue={x:Null}}"
                                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                                </Border>
                                                                <TextBlock Text="{Binding Champion}" VerticalAlignment="Center"
                                                                           Foreground="{StaticResource TextPrimary}" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Summoner" Binding="{Binding Summoner}" Width="*" />
                                                <DataGridTextColumn Header="Lvl" Binding="{Binding Level}" Width="Auto" />
                                                <DataGridTextColumn Header="KDA" Binding="{Binding Kda}" Width="Auto" />
                                                <DataGridTextColumn Header="CS" Binding="{Binding Cs}" Width="Auto" />
                                                <!-- Inventario como strip de íconos; el nombre queda en el tooltip. -->
                                                <DataGridTemplateColumn Header="Items" Width="2*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <ItemsControl ItemsSource="{Binding ItemIcons}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Width="20" Height="20" CornerRadius="3" Margin="0,0,3,0"
                                                                                BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                                                                ToolTip="{Binding Name}">
                                                                            <Image Source="{Binding IconUrl, TargetNullValue={x:Null}}"
                                                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- PESTAÑA CHAMP SELECT -->
                <TabItem Header="CHAMP SELECT">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,4,0,16">

                            <!-- ===== ASESOR DE BANCA (ARAM): mejor intercambio para equilibrar ===== -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BenchVerdict}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="BENCH ADVISOR" Style="{StaticResource SectionHeader}" Margin="10,6,0,6" />
                                <Border Style="{StaticResource GoldCard}" Padding="16,12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding BenchVerdict}" FontSize="16" FontWeight="Bold"
                                                   TextWrapping="Wrap" Foreground="{StaticResource TextPrimary}" />
                                        <TextBlock Text="{Binding BenchSummary}" FontSize="13" Margin="0,8,0,0"
                                                   TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" />
                                        <TextBlock Text="{Binding BenchLine}" FontSize="13" Margin="0,2,0,0"
                                                   TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" />
                                    </StackPanel>
                                </Border>
                                <ItemsControl ItemsSource="{Binding BenchSuggestions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource Card}" Padding="14">
                                                <DockPanel>
                                                    <Border DockPanel.Dock="Left" Width="36" Height="36" CornerRadius="4"
                                                            Margin="0,0,12,0" VerticalAlignment="Top"
                                                            BorderBrush="{StaticResource CardBorderStrong}" BorderThickness="1">
                                                        <Image Source="{Binding IconUrl, TargetNullValue={x:Null}}"
                                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                                    </Border>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold"
                                                                   Foreground="{StaticResource TextPrimary}" />
                                                        <TextBlock Text="{Binding Reasons}" FontSize="13" TextWrapping="Wrap"
                                                                   Foreground="{StaticResource TextMuted}" Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- ===== RUNAS EN CHAMP SELECT — se aplican solas al lockear campeón ===== -->
                            <Border Padding="16,12">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource GoldCard}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RunesLine}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="RUNES &amp; SKILLS — APPLIED AUTOMATICALLY ON LOCK-IN"
                                               FontFamily="{StaticResource DisplayFontCondensed}"
                                               FontSize="12" FontWeight="Bold" Foreground="{StaticResource Gold}"
                                               Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding RunesLine}" FontSize="13" TextWrapping="Wrap"
                                               Foreground="{StaticResource TextPrimary}" />
                                    <TextBlock Text="{Binding SkillOrderLine}" FontSize="13"
                                               TextWrapping="Wrap" Margin="0,4,0,0"
                                               Foreground="{StaticResource TextPrimary}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button Content="Re-apply runes" Command="{Binding ApplyRunesCommand}"
                                                Style="{StaticResource PrimaryButton}" Padding="14,5" />
                                        <TextBlock Text="{Binding RunesStatus}" FontSize="12"
                                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                                                   Margin="12,0,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="{Binding DraftPhase}" Style="{StaticResource SectionHeader}" />
                            <Border Style="{StaticResource Card}">
                                <TextBlock Text="{Binding Bans}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" />
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="YOUR TEAM" Style="{StaticResource SectionHeader}" />
                                    <ItemsControl ItemsSource="{Binding MyTeam}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource Card}" Padding="12">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="4" CornerRadius="2" Background="{Binding Accent}" Margin="0,0,10,0" />
                                                        <Border Width="34" Height="34" CornerRadius="4" Margin="0,0,10,0"
                                                                VerticalAlignment="Center"
                                                                BorderBrush="{StaticResource CardBorderStrong}" BorderThickness="1">
                                                            <Image Source="{Binding IconUrl, TargetNullValue={x:Null}}"
                                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Position}" Style="{StaticResource CardTitle}" />
                                                            <TextBlock Text="{Binding Champion}" Foreground="{StaticResource TextPrimary}"
                                                                       FontWeight="SemiBold" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="ENEMY TEAM" Style="{StaticResource SectionHeader}" />
                                    <ItemsControl ItemsSource="{Binding TheirTeam}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource Card}" Padding="12">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="4" CornerRadius="2" Background="{Binding Accent}" Margin="0,0,10,0" />
                                                        <Border Width="34" Height="34" CornerRadius="4" Margin="0,0,10,0"
                                                                VerticalAlignment="Center"
                                                                BorderBrush="{StaticResource CardBorderStrong}" BorderThickness="1">
                                                            <Image Source="{Binding IconUrl, TargetNullValue={x:Null}}"
                                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Position}" Style="{StaticResource CardTitle}" />
                                                            <TextBlock Text="{Binding Champion}" Foreground="{StaticResource TextPrimary}"
                                                                       FontWeight="SemiBold" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>

                            <Border Style="{StaticResource Card}" Margin="6,12,6,6">
                                <TextBlock Foreground="{StaticResource TextFaint}" TextWrapping="Wrap"
                                           Text="Note: champion names come from the Data Dragon catalog; until it loads, the ID is shown." />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
