<Window x:Class="ParadoxLoLCompanion.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Item Advisor Overlay"
        SizeToContent="WidthAndHeight"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize"
        MouseLeftButtonDown="OnDrag">

    <!-- Overlay in-game: las recomendaciones de items del MATCH tab (con su WHY),
         al costado la bota sugerida SOLO si aún no llevás botas terminadas (BootsName
         ya viene vacío en ese caso desde el ViewModel), y arriba el selector de
         rol/build — el mismo override por partida del MATCH tab, ahora accionable
         sin salir del juego. -->
    <Border Background="#F00B0E0C" BorderBrush="{StaticResource CardBorderStrong}"
            BorderThickness="1" CornerRadius="4" Padding="10,8,10,10">
        <DockPanel>

            <!-- Panel lateral: la bota recomendada. -->
            <Border DockPanel.Dock="Right" Width="128" Margin="8,0,0,0" Padding="8,6"
                    Background="#101512" BorderBrush="{StaticResource CardBorder}"
                    BorderThickness="1" CornerRadius="3" VerticalAlignment="Top">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding BootsName}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="BOOTS" FontFamily="{StaticResource HudFont}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{StaticResource TextFaint}" />
                    <Border Width="40" Height="40" CornerRadius="3" Margin="0,6,0,6"
                            HorizontalAlignment="Left"
                            BorderBrush="{StaticResource CardBorderStrong}" BorderThickness="1">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding BootsIconUrl, TargetNullValue={x:Null}}"
                                        Stretch="UniformToFill" />
                        </Border.Background>
                    </Border>
                    <TextBlock Text="{Binding BootsName}" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding BootsChip}" Margin="0,4,0,0"
                               FontFamily="{StaticResource HudFont}" FontSize="9" FontWeight="Bold"
                               Foreground="{StaticResource Neon}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding BootsSub}" Margin="0,6,0,0"
                               FontFamily="{StaticResource HudFont}" FontSize="9"
                               Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"
                               LineHeight="13" />
                </StackPanel>
            </Border>

            <StackPanel Width="310">
                <DockPanel Margin="2,0,2,8">
                    <TextBlock DockPanel.Dock="Right" Text="CTRL+X" VerticalAlignment="Center"
                               FontFamily="{StaticResource HudFont}" FontSize="9"
                               Foreground="{StaticResource TextFaint}" />
                    <TextBlock Text="ITEM ADVISOR" FontFamily="{StaticResource HudFont}"
                               FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gold}" />
                </DockPanel>

                <!-- Selector de rol/build: bindea BuildRoles del MainViewModel compartido;
                     cambiarlo recalcula items y botas al instante (OnBuildRoleSelected).
                     GroupName propio: los radios del overlay viven en otra ventana que los
                     del MATCH tab, así que WPF no los agrupa entre sí; se mantienen en sync
                     solo por el IsChecked del ViewModel. AUTO = detección automática. -->
                <TextBlock Text="BUILD" Margin="2,0,2,4" FontFamily="{StaticResource HudFont}"
                           FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextFaint}" />
                <ItemsControl ItemsSource="{Binding BuildRoles}" Margin="2,0,-2,8">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><UniformGrid Columns="4" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <RadioButton GroupName="OverlayBuildRole" Content="{Binding Label}"
                                         Style="{StaticResource OverlaySegmentRadio}"
                                         IsChecked="{Binding IsChecked, Mode=TwoWay}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding ItemRecos}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#101512" BorderBrush="{StaticResource CardBorder}"
                                    BorderThickness="1" CornerRadius="3" Margin="0,0,0,6" Padding="8,6">
                                <DockPanel>
                                    <!-- Barrita de categoría (CORE/COUNTER/…): el color basta, sin texto. -->
                                    <Border DockPanel.Dock="Left" Width="3" Background="{Binding CategoryBrush}"
                                            CornerRadius="1" Margin="0,1,9,1" />
                                    <Border DockPanel.Dock="Left" Width="34" Height="34" CornerRadius="3"
                                            Margin="0,0,10,0" VerticalAlignment="Top"
                                            BorderBrush="{StaticResource CardBorderStrong}" BorderThickness="1">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding IconUrl, TargetNullValue={x:Null}}"
                                                        Stretch="UniformToFill" />
                                        </Border.Background>
                                    </Border>
                                    <StackPanel>
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Right" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Cost}" HorizontalAlignment="Right"
                                                           FontFamily="{StaticResource DisplayFont}" FontSize="13"
                                                           Foreground="{StaticResource Gold}" />
                                                <TextBlock Text="{Binding GoldPercent}" HorizontalAlignment="Right"
                                                           FontFamily="{StaticResource HudFont}" FontSize="9" FontWeight="Bold"
                                                           Foreground="{Binding AffordBrush}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding BuyBarText}" Margin="0,2,0,0"
                                                           FontFamily="{StaticResource HudFont}" FontSize="10"
                                                           Foreground="{Binding AffordBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DockPanel>
                                        <!-- WHY: las razones, compactas debajo de cada item. -->
                                        <TextBlock Text="{Binding Reasons}" Margin="0,4,0,0"
                                                   FontFamily="{StaticResource HudFont}" FontSize="9"
                                                   Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"
                                                   LineHeight="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Reasons}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Augments OFRECIDOS ahora (OCR de la pantalla; muerto o en la
                     gracia post-respawn con el picker aún abierto): el mejor según
                     Blitz resaltado en dorado. -->
                <StackPanel Margin="2,2,2,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OfferedAugments.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="OFFERED NOW" FontFamily="{StaticResource HudFont}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{StaticResource Amber}" Margin="0,2,0,4" />
                    <ItemsControl ItemsSource="{Binding OfferedAugments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="1" CornerRadius="3" Margin="0,0,0,4" Padding="7,5">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#101512" />
                                            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBest}" Value="True">
                                                    <Setter Property="Background" Value="#241C08" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource Gold}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Verdict}"
                                                   FontFamily="{StaticResource HudFont}" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource Gold}" VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />
                                        <TextBlock Text="{Binding TierLabel}" FontFamily="{StaticResource HudFont}"
                                                   FontSize="11" FontWeight="Bold" Foreground="{Binding TierBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Bold" Margin="7,0,0,0"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Recomendados de augments (Mayhem): SOLO los ~4 que valen (★ de tu
                     campeón + S), SOLO durante la ventana de pick, y OCULTO si el OCR
                     ya identificó los 3 ofrecidos (OFFERED NOW manda). El catálogo
                     completo vive en el MATCH tab. -->
                <StackPanel Margin="2,2,2,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OverlayAugments.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding MayhemPickWindow}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasOfferedAugments}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="RECOMMENDED AUGMENTS" FontFamily="{StaticResource HudFont}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{StaticResource TextFaint}" Margin="0,2,0,4" />
                    <ItemsControl ItemsSource="{Binding OverlayAugments}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="1" CornerRadius="3" Margin="0,0,4,4" Padding="5,3"
                                        ToolTip="{Binding RarityLabel}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#101512" />
                                            <Setter Property="BorderBrush" Value="{Binding RarityBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTop}" Value="True">
                                                    <Setter Property="Background" Value="#241C08" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource Gold}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TopChip}" FontFamily="{StaticResource HudFont}"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,5,0"
                                                   Foreground="{StaticResource Gold}" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTop}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding TierLabel}" FontFamily="{StaticResource HudFont}"
                                                   FontSize="10" FontWeight="Bold" Foreground="{Binding TierBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}" FontSize="11" Margin="5,0,0,0"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                                        <TextBlock Text="★" Margin="4,0,0,0" FontSize="10"
                                                   Foreground="{StaticResource Gold}" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FitsMyChampion}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <TextBlock Text="Waiting for a live match…" Margin="2,2,2,4"
                           FontFamily="{StaticResource HudFont}" FontSize="11"
                           Foreground="{StaticResource TextMuted}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ItemRecos.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
